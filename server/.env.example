PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (Docker local or Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connectbc
# Local DB: from repo root run `docker compose up -d`, then apply migrations in order:
#   migrations/001_initial.sql, 002_users.sql, 003_event_website_url.sql, 004_event_city.sql

# JWT for Bearer auth (must match across restarts)
JWT_SECRET=supersecretkey

# Optional: Mapbox geocoding (faster). If unset, the API uses OpenStreetMap Nominatim + BC city fallbacks.
MAPBOX_TOKEN=your_token_here

# Optional: identify your app to Nominatim (recommended in production).
# NOMINATIM_USER_AGENT=ConnectBC/1.0 (your-contact-url-or-email)
