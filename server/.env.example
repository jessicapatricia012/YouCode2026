PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (Docker local or Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connectbc
# Local DB: from repo root run `docker compose up -d`, then apply migrations:
#   migrations/001_initial.sql then migrations/002_users.sql

# JWT for Bearer auth (must match across restarts)
JWT_SECRET=supersecretkey

# Optional: Mapbox token for seed geocoding. If unset/invalid, seed uses built-in lat/lng.
MAPBOX_TOKEN=your_token_here
