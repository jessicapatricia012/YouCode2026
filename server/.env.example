PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (Docker local or Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connectbc
# Local DB: from repo root run `docker compose up -d`, then apply migrations in order:
#   migrations/001_initial.sql … 006_admin_event_removal.sql (see server/migrations/)
# Seed: `npm run seed` truncates orgs/users (and cascaded events/signups/etc.). `npm run seed:append`
#   adds demo data only (no truncate; skips seed events if same org_id+title exists).

# JWT for Bearer auth (must match across restarts)
JWT_SECRET=supersecretkey

# Admin UI: sign in at /login with this email + password (before visitor/org accounts are checked).
# Comma-separated for multiple emails (same ADMIN_PASSWORD for all).
# ADMIN_EMAILS=you@example.com
# ADMIN_PASSWORD=change-me-in-production

# Optional: email organizers when an admin removes their event (nodemailer SMTP).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="ConnectBC <noreply@example.com>"

# Optional: Mapbox geocoding (faster). If unset, the API uses OpenStreetMap Nominatim + BC city fallbacks.
MAPBOX_TOKEN=your_token_here

# Optional: identify your app to Nominatim (recommended in production).
# NOMINATIM_USER_AGENT=ConnectBC/1.0 (your-contact-url-or-email)
