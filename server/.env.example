PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (Docker local or Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/commonground

# JWT for Bearer auth (must match across restarts)
JWT_SECRET=supersecretkey

# Mapbox token for server-side geocoding in npm run seed (secret or public token)
MAPBOX_TOKEN=your_token_here
